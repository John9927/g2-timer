{
  "name": "g2-timer",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:sim": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npx @evenrealities/evenhub-simulator http://localhost:5173\"",
    "dev:qr": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && node scripts/show-qr.js\"",
    "build": "vite build",
    "preview": "vite preview --host",
    "qr": "node scripts/show-qr.js",
    "qr:vercel": "node scripts/generate-qr-vercel.js"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.7"
  },
  "devDependencies": {
    "@evenrealities/evenhub-simulator": "latest",
    "@types/node": "^20.10.0",
    "concurrently": "^8.2.2",
    "qrcode-terminal": "^0.12.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
